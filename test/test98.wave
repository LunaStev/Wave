// wave-test: host-os=linux, host-arch=aarch64
fun syscall0(id: i64) -> i64 {
    var ret: i64;
    asm {
        "svc #0"
        in("x8") id
        out("x0") ret
    }
    return ret;
}

fun syscall3(id: i64, a1: i64, a2: i64, a3: i64) -> i64 {
    var ret: i64;
    asm {
        "svc #0"
        in("x8") id
        in("x0") a1
        in("x1") a2
        in("x2") a3
        out("x0") ret
    }
    return ret;
}

fun syscall6(id: i64, a1: i64, a2: i64, a3: i64, a4: i64, a5: i64, a6: i64) -> i64 {
    var ret: i64;
    asm {
        "svc #0"
        in("x8") id
        in("x0") a1
        in("x1") a2
        in("x2") a3
        in("x3") a4
        in("x4") a5
        in("x5") a6
        out("x0") ret
    }
    return ret;
}

fun main() {
    let a: i64 = syscall0(172);
    let b: i64 = syscall3(64, 1, 2, 3);
    let c: i64 = syscall6(222, 1, 2, 3, 4, 5, 6);
    println("{} {} {}", a, b, c);
}
