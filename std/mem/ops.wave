import("std::mem::consts");

fun mem_set(dst: ptr<u8>, value: u8, size: i64) {
    let mut i: i64 = 0;
    while (i < size) {
        deref dst[i] = value;
        i += 1;
    }
}

fun mem_zero(dst: ptr<u8>, size: i64) {
    mem_set(dst, 0, size);
}

fun mem_copy(dst: ptr<u8>, src: ptr<u8>, size: i64) {
    let mut i: i64 = 0;
    while (i < size) {
        deref dst[i] = src[i];
        i += 1;
    }
}

fun mem_move(dst: ptr<u8>, src: ptr<u8>, size: i64) {
    if (size <= 0) {
        return;
    }

    if (dst == src) {
        return;
    }

    if ((dst as i64) < (src as i64)) {
        let mut i: i64 = 0;
        while (i < size) {
            deref dst[i] = src[i];
            i += 1;
        }
        return;
    }

    let mut i: i64 = size;
    while (i > 0) {
        i -= 1;
        deref dst[i] = src[i];
    }
}

fun mem_cmp(a: ptr<u8>, b: ptr<u8>, size: i64) -> i32 {
    let mut i: i64 = 0;

    while (i < size) {
        let mut av: u8 = a[i];
        let mut bv: u8 = b[i];

        if (av < bv) {
            return -1;
        }

        if (av > bv) {
            return 1;
        }

        i += 1;
    }

    return 0;
}

fun mem_eq(a: ptr<u8>, b: ptr<u8>, size: i64) -> bool {
    if (mem_cmp(a, b, size) == 0) {
        return true;
    }

    return false;
}

fun mem_find_byte(src: ptr<u8>, size: i64, value: u8) -> i64 {
    let mut i: i64 = 0;
    while (i < size) {
        if (src[i] == value) {
            return i;
        }
        i += 1;
    }
    return -1;
}

fun mem_swap<T>(a: ptr<T>, b: ptr<T>) {
    let mut tmp: T = deref a;
    deref a = deref b;
    deref b = tmp;
}

fun mem_copy_items<T>(dst: ptr<T>, src: ptr<T>, count: i64, elem_size: i64) {
    if (count <= 0 || elem_size <= 0) {
        return;
    }

    mem_copy(dst as ptr<u8>, src as ptr<u8>, count * elem_size);
}

fun mem_set_items<T>(dst: ptr<T>, value: T, count: i64, elem_size: i64) {
    if (count <= 0 || elem_size <= 0) {
        return;
    }

    let mut i: i64 = 0;
    while (i < count) {
        deref dst[i] = value;
        i += 1;
    }
}

fun mem_move_items<T>(dst: ptr<T>, src: ptr<T>, count: i64, elem_size: i64) {
    if (count <= 0 || elem_size <= 0) {
        return;
    }

    mem_move(dst as ptr<u8>, src as ptr<u8>, count * elem_size);
}

fun mem_zero_items<T>(dst: ptr<T>, count: i64, elem_size: i64) {
    if (count <= 0 || elem_size <= 0) {
        return;
    }

    mem_zero(dst as ptr<u8>, count * elem_size);
}

fun mem_copy_checked(dst: ptr<u8>, dst_cap: i64, src: ptr<u8>, src_len: i64) -> i64 {
    if (dst_cap < 0 || src_len < 0) {
        return MEM_ERR_INVALID;
    }

    if (src_len > dst_cap) {
        return MEM_ERR_NO_SPACE;
    }

    if (src_len == 0) {
        return 0;
    }

    mem_copy(dst, src, src_len);
    return src_len;
}

fun mem_move_checked(dst: ptr<u8>, dst_cap: i64, src: ptr<u8>, src_len: i64) -> i64 {
    if (dst_cap < 0 || src_len < 0) {
        return MEM_ERR_INVALID;
    }

    if (src_len > dst_cap) {
        return MEM_ERR_NO_SPACE;
    }

    if (src_len == 0) {
        return 0;
    }

    mem_move(dst, src, src_len);
    return src_len;
}

fun mem_set_checked(dst: ptr<u8>, dst_cap: i64, value: u8, len: i64) -> i64 {
    if (dst_cap < 0 || len < 0) {
        return MEM_ERR_INVALID;
    }

    if (len > dst_cap) {
        return MEM_ERR_NO_SPACE;
    }

    if (len == 0) {
        return 0;
    }

    mem_set(dst, value, len);
    return len;
}

fun mem_zero_checked(dst: ptr<u8>, dst_cap: i64, len: i64) -> i64 {
    return mem_set_checked(dst, dst_cap, 0, len);
}
