import("std::sys::fs");

fun env_getcwd(dst: ptr<u8>, cap: i64) -> i64 {
    var r: i64 = getcwd(dst, cap);
    if (r <= 0) {
        return -1;
    }

    var n: i64 = 0;
    while (dst[n] != 0) {
        n += 1;
    }

    return n;
}

fun env_chdir(path: str) -> i64 {
    return chdir(path);
}

fun env_access(path: str, mode: i32) -> i64 {
    return access(path, mode);
}
